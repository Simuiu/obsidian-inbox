# WeChat Official Account automation config.
# Copy to a local ignored file before use, for example:
#   cp marketing/automation/wechat-official-account.env.example secrets/wechat-official-account.env
#
# Do not commit real values. Do not paste secrets into chat.

WECHAT_OFFICIAL_APPID=
WECHAT_OFFICIAL_SECRET=

# Optional. Used in draft metadata and preview.
WECHAT_OFFICIAL_AUTHOR=
WECHAT_OFFICIAL_CONTENT_SOURCE_URL=https://github.com/Simuiu/obsidian-inbox

# Optional. If empty, the script can upload the cover image as thumb when
# --upload-assets is used.
WECHAT_OFFICIAL_THUMB_MEDIA_ID=
